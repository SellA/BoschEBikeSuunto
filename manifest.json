{
  "name": "Bosch eBike",
  "version": "1.0",
  "author": "Michele",
  "description": "Bosch eBike Live Data Interface",
  "type": "device",
  "usage": "workout",
  "modificationTime": 1746921600,
  "template": [
    { "name": "t.html" }
  ],
  "settings": [
    { "shownName": "Power bar 100% W", "path": "appSettings.powerBarMax", "type": "int", "min": 100, "max": 1000, "inputType": "slider" }
  ],
  "out": [
    { "name": "con" },
    { "name": "speed",   "log": true, "shownName": "eBike speed km/h",  "format": "Count_Threedigits" },
    { "name": "cadence", "log": true, "shownName": "Cadence rpm",        "format": "Count_Threedigits" },
    { "name": "power",   "log": true, "shownName": "Power W",            "format": "Count_Fourdigits"  },
    { "name": "battery", "log": true, "shownName": "Battery %",          "format": "Count_Threedigits" },
    { "name": "odo" },
    { "name": "charger" },
    { "name": "light" },
    { "name": "powerBarLevel" },
    { "name": "batteryBarLevel" }
  ]
}
